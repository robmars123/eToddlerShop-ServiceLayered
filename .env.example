DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/appdb
DEBUG=false

# ── Azure Entra External ID (CIAM) ──────────────────────────────────────────
# Tenant subdomain is the short name shown in the Entra portal overview
# (e.g. if your domain is "contoso.ciamlogin.com", subdomain is "contoso")
AZURE_ENTRA_TENANT_ID=<your-tenant-id-guid>
AZURE_ENTRA_CLIENT_ID=<your-app-client-id-guid>
AZURE_ENTRA_AUTHORITY=https://<subdomain>.ciamlogin.com/<your-tenant-id-guid>
# Audience that must match the 'aud' claim in the access token.
# For a single-app setup this equals AZURE_ENTRA_CLIENT_ID.
# If you registered a separate API app, put that app's client ID here.
AZURE_ENTRA_AUDIENCE=<your-app-client-id-guid>
# Email of the user who should receive the 'admin' role on first login
AZURE_ENTRA_ADMIN_EMAIL=admin@yourdomain.com

# ── Azure Storage ────────────────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=products

# ── Azure OpenAI ─────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_KEY=<your-api-key>
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_EMBEDDINGS=text-embedding-3-small
AZURE_OPENAI_CHAT=gpt-4o-mini

# ── Azure Speech ─────────────────────────────────────────────────────────────
AZURE_SPEECH_ENDPOINT=https://centralus.api.cognitive.microsoft.com/
AZURE_SPEECH_KEY=<your-speech-key>
AZURE_SPEECH_REGION=centralus

# ── Misc ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
REDIS_URL=redis://localhost:6379
DATABASE_SSL=false
