# Copy this file to .env.local and fill in your values

# Vite API URL — where your FastAPI backend is running
VITE_API_URL=http://localhost:8000

# ── Azure Entra External ID ───────────────────────────────────────────────────
# Authority: https://{subdomain}.ciamlogin.com/{tenant-id}
# (subdomain = your tenant short name, e.g. "contoso" for contoso.ciamlogin.com)
VITE_ENTRA_AUTHORITY=https://<subdomain>.ciamlogin.com/<tenant-id>

# App (client) ID from your Entra External ID app registration
VITE_ENTRA_CLIENT_ID=<your-client-id-guid>

# Scopes to request for the access token.
# Must include the API scope you exposed on the app registration.
# For a single-app setup: "openid offline_access api://{client-id}/access_as_user"
VITE_ENTRA_SCOPES=openid offline_access api://<your-client-id-guid>/access_as_user
