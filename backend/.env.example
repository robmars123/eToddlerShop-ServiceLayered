# Copy to .env and fill in your values
# Never commit .env to source control

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/appdb
DATABASE_SSL=false
DEBUG=false

# --- Redis (optional — app fails open if unavailable) ---
REDIS_URL=redis://localhost:6379

# --- CORS (comma-separated extra origins beyond localhost) ---
CORS_ORIGINS=

# --- Azure Entra External ID (CIAM) ---
AZURE_ENTRA_TENANT_ID=
AZURE_ENTRA_CLIENT_ID=
AZURE_ENTRA_AUTHORITY=https://<subdomain>.ciamlogin.com/<tenant-id>
AZURE_ENTRA_AUDIENCE=
AZURE_ENTRA_ADMIN_EMAIL=
AZURE_ENTRA_ADMIN_OID=

# --- Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_KEY=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_EMBEDDINGS=text-embedding-3-small
AZURE_OPENAI_CHAT=gpt-4o-mini

# --- Azure Cognitive Services Speech ---
AZURE_SPEECH_ENDPOINT=https://centralus.api.cognitive.microsoft.com/
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=centralus

# --- Azure Blob Storage ---
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=products
